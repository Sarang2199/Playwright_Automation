pipeline {
    agent {
        docker {
            image 'mcr.microsoft.com/playwright:v1.58.1-jammy'
            args '--user root --ipc=host'
            // CRITICAL FIX: This keeps the workspace context alive for the post block
            reuseNode true 
        }
    }

    stages {
        stage('Install Dependencies') {
            steps {
                sh 'npm install'
            }
        }

        stage('Run Tests') {
            steps {
                sh 'npx playwright test --workers=4 || true'
            }
        }
    }

    post {
        always {
            // These steps now have access to hudson.FilePath
            archiveArtifacts artifacts: 'test-results/**/*.zip', allowEmptyArchive: true
            allure includeProperties: false, jdk: '', results: [[path: 'allure-results']]
            cleanWs() 
        }
    }
}