pipeline {
    agent any

    tools {
        nodejs 'node'
        allure 'Allure_1.0' // Ensure this matches your Tool name
    }

    stages {
        stage('Install Dependencies') {
            steps {
                // This downloads @playwright/test and other packages
                sh 'npm install'
                // This installs the actual browser binaries (Chromium, etc.)
                sh 'npx playwright test --workers=4 || true'            }
        }

        stage('Run Tests') {
            steps {
                sh 'npx playwright test || true'
            }
        }
    }

    post {
        always {
            // 1. Archive first so you don't lose the data
            archiveArtifacts artifacts: 'test-results/**/*.zip', allowEmptyArchive: true
            
            // 2. Generate report
            allure includeProperties: false, jdk: '', results: [[path: 'allure-results']]
            
            // 3. Clean the workspace
            cleanWs() 
        }
    }
}
