pipeline {
    agent {
        docker {
            // This image comes with Node.js and all browser dependencies pre-installed
            image 'mcr.microsoft.com/playwright:v1.58.1-jammy'
            // Necessary to run browsers inside Docker without 'sandbox' issues
            args '--user root'
        }
    }

    stages {
        stage('Install Dependencies') {
            steps {
                // Since we are in Docker, we only need npm install.
                // We don't need 'npx playwright install --with-deps' 
                // because the image already has them!
                sh 'npm install'
            }
        }

        stage('Run Tests') {
            steps {
                sh 'npx playwright test --workers=4 || true'
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'test-results/**/*.zip', allowEmptyArchive: true
            allure includeProperties: false, jdk: '', results: [[path: 'allure-results']]
            cleanWs()
        }
    }
}